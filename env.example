# Database
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# NextAuth Configuration
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production-must-be-32-chars

# Vercel Blob Storage (pour les uploads de fichiers)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token_from_vercel_dashboard

# Resend — domaine vérifié https://resend.com/domains (nexkeep.fr)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="NexKeep <noreply@nexkeep.fr>"
ADMIN_EMAIL=contact@nexkeep.fr
# Logs détaillés email (optionnel)
# EMAIL_DEBUG=true
